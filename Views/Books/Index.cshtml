@model List<Book>

@if (TempData["Success"] != null)
{
    <p style="color:green">@TempData["Success"]</p>
}

<a href="/Books/Add" class="btn btn-primary">Yeni Kitap</a>

<table class="table">
    <tr>
        <th>Başlık</th>
        <th>Yazar</th>
        <th>Fiyat</th>
        <th>Stok</th>
        <th>İşlem</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Price</td>
            <td>@item.Stock</td>
            <td>
                <a href="/Books/Update/@item.Id">Güncelle</a>
                <a href="/Books/Remove/@item.Id">Sil</a>
            </td>
        </tr>
    }
</table>